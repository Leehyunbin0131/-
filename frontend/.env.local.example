# 비우면 브라우저는 같은 출처(예: localhost:3000)의 /api/v1 로 요청하고, Next가 백엔드로 넘깁니다.
# 이렇게 하면 localhost:3000 + API 127.0.0.1:8000 조합에서 게스트 쿠키가 빠지는 문제를 피할 수 있습니다.
NEXT_PUBLIC_API_BASE_URL=

# Next 서버만 사용 (브라우저에 노출되지 않음). 프록시 대상 FastAPI 주소.
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# 휴대폰 등에서 PC의 LAN IP로 접속할 때 Next dev HMR 허용(호스트만, 콤마 구분)
# NEXT_ALLOWED_DEV_ORIGINS=192.168.45.180
