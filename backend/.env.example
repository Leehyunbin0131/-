COUNSEL_OPENAI_API_KEY=
COUNSEL_FRONTEND_APP_URL=http://127.0.0.1:3000
COUNSEL_API_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
COUNSEL_TRIAL_TURN_LIMIT=5
# 0이면 후속 상담 LLM에 약 30턴 분량의 대화를 기본으로 넣음. 고정하려면 양수로 설정
COUNSEL_FOLLOWUP_CONVERSATION_MAX_MESSAGES=0
# 일반 API(임베딩·채팅) 타임아웃(초). Responses는 아래 별도 값 사용.
# COUNSEL_REQUEST_TIMEOUT_SECONDS=60
# Responses API(모집결과 파일·추론)용 긴 읽기 타임아웃(초). APITimeoutError 시 늘리세요.
# COUNSEL_OPENAI_RESPONSES_TIMEOUT_SECONDS=900
COUNSEL_OPENAI_REASONING_EFFORT=medium
COUNSEL_OPENAI_FILE_BATCH_SIZE=10
# 요약 시 모집결과 파일 후보 최대 개수(프로필 매칭 점수 상위만 LLM에 전달)
# COUNSEL_OPENAI_SUMMARY_MAX_CANDIDATE_FILES=32
# Responses API만 해당. 비우거나 미설정이면 temperature를 보내지 않음(gpt-5 등).
# COUNSEL_OPENAI_RESPONSES_TEMPERATURE=0.2
COUNSEL_COOKIE_SECURE=false
# Web enrichment is used for dorm, tuition, scholarship, and campus-life facts.
COUNSEL_OPENAI_WEB_SEARCH_ENABLED=true
# COUNSEL_OPENAI_WEB_SEARCH_MODEL=gpt-5.4-nano
